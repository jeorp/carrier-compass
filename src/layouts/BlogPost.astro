---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, category, tags, related, isAffiliate } = Astro.props;

const authors: Record<string, { name: string; bio: string; icon: string }> = {
	yuki: {
		name: 'Yuki',
		icon: '☕',
		bio: 'このサイトの編集リーダー。アナウンサーを目指した過去を持つ29歳。大手メーカーからスタートアップへ転職した現役営業職。休日はカフェで充電しながらキャリアについて発信中。',
	},
	syun: {
		name: 'Syun',
		icon: '💼',
		bio: '早稲田大学ラグビー部出身。大手外資系コンサルを経て、32歳でフリーランスのキャリアコンサルタントとして独立。サウナとルーティンをこよなく愛する。',
	},
	kz: {
		name: 'kz',
		icon: '🛠️',
		bio: '26歳のソフトウェアエンジニア。エンジニア目線でキャリアや副業・フリーランスについて発信する。',
	},
};

const authorProfile = author ? authors[author] : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('blog');

// URLから現在記事のIDを取得して除外
const segments = Astro.url.pathname.split('/').filter(Boolean);
const currentId = segments[segments.length - 1];

const MAX_RELATED = 3;

const scoredPosts = (() => {
	const currentTags = tags ?? [];
	return allPosts
		.filter((p) => p.id !== currentId)
		.map((p) => {
			let score = 0;
			if (p.data.author === author) score += 3;
			if (p.data.category === category) score += 2;
			score += (p.data.tags ?? []).filter((t) => currentTags.includes(t)).length;
			return { post: p, score };
		})
		.filter(({ score }) => score > 0)
		.sort((a, b) => b.score - a.score)
		.map(({ post }) => post);
})();

const manualPosts = related?.length ? allPosts.filter((p) => related.includes(p.id)) : [];
const candidatePosts = manualPosts.length ? manualPosts : scoredPosts;

const relatedPosts = candidatePosts.slice(0, MAX_RELATED);

const shareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin-top: 0.75em;
			}
			.category {
				background: var(--accent);
				color: white;
				font-size: 0.75em;
				padding: 0.25em 0.75em;
				border-radius: 999px;
				font-weight: 700;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				font-size: 0.75em;
				padding: 0.25em 0.75em;
				border-radius: 999px;
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.tag:hover {
				background: rgb(var(--gray));
				color: white;
			}
			.author-profile {
				display: flex;
				align-items: flex-start;
				gap: 1em;
				margin-top: 3em;
				padding: 1.5em;
				background: rgb(var(--gray-light));
				border-radius: 12px;
			}
			.author-icon {
				font-size: 2.5em;
				line-height: 1;
				flex-shrink: 0;
			}
			.author-name {
				font-weight: 700;
				margin-bottom: 0.25em;
			}
			.author-bio {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.author-link {
				display: inline-block;
				margin-top: 0.75em;
				font-size: 0.85em;
				color: var(--accent);
				text-decoration: none;
			}
			.author-link:hover {
				text-decoration: underline;
			}
			.related {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.related-title {
				font-size: 0.8rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin: 0 0 1em;
			}
			.related-list {
				display: flex;
				flex-direction: column;
				gap: 0.75em;
			}
			.related-card {
				display: block;
				padding: 1em 1.2em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease;
			}
			.related-card:hover {
				border-color: var(--accent);
			}
			.related-card-author {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				margin-bottom: 0.3em;
			}
			.related-card-title {
				font-size: 0.95rem;
				font-weight: 700;
				line-height: 1.4;
				margin: 0;
			}
			.share {
				margin-top: 2.5em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				display: flex;
				align-items: center;
				gap: 0.75em;
			}
			.share-label {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				font-weight: 700;
				letter-spacing: 0.05em;
			}
			.share-x {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1.1em;
				border-radius: 999px;
				background: #000;
				color: white;
				font-size: 0.85rem;
				font-weight: 700;
				text-decoration: none;
				transition: opacity 0.15s ease;
			}
			.share-x:hover { opacity: 0.8; }
			.pr-notice {
				font-size: 0.78rem;
				color: rgb(var(--gray));
				margin: 0 0 1.5em;
			}
			@media (max-width: 720px) {
				.author-profile {
					flex-direction: column;
					gap: 0.75em;
				}
				.author-icon {
					font-size: 1.8em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" fetchpriority="high" loading="eager" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最終更新日: <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<div class="meta">
							{category && <span class="category">{category}</span>}
							{tags && tags.map((tag) => <a href={`${base}/blog/tag/${tag}/`} class="tag">#{tag}</a>)}
						</div>
						<hr />
					</div>
					{isAffiliate && (
						<p class="pr-notice">※ 本記事はアフィリエイト広告を含みます。</p>
					)}
					<slot />
					{author && relatedPosts.length > 0 && (
						<div class="related">
							<p class="related-title">こんな記事も読まれています</p>
							<div class="related-list">
								{relatedPosts.map((p) => (
									<a class="related-card" href={`${base}/blog/${p.id}/`}>
										<div class="related-card-author">
											{p.data.author === 'yuki' ? '☕ Yuki' : p.data.author === 'kz' ? '🛠️ kz' : '💼 Syun'}
										</div>
										<p class="related-card-title">{p.data.title}</p>
									</a>
								))}
							</div>
						</div>
					)}
					{authorProfile && (
					<div class="author-profile">
						<div class="author-icon">{authorProfile.icon}</div>
						<div class="author-info">
							<div class="author-name">{authorProfile.name}</div>
							<p class="author-bio">{authorProfile.bio}</p>
						<a class="author-link" href={`${base}/blog/author/${author}/`}>{authorProfile.name}の記事をもっと読む →</a>
					</div>
				</div>
			)}
					{author && (
						<div class="share">
							<span class="share-label">シェア</span>
							<a class="share-x" href={shareUrl} target="_blank" rel="noopener noreferrer">
								𝕏 でポストする
							</a>
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
