---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = ['転職', 'スキルアップ', '副業', '働き方'];

const writers = [
	{ id: 'yuki', icon: '☕', name: 'Yuki', tagline: 'アナウンサーを諦め、衝動で転職した。それでも営業は続けている。' },
	{ id: 'syun', icon: '💼', name: 'Syun', tagline: '年収900万を捨てて、ゼロの月もあった。それでも後悔していない。' },
	{ id: 'kz', icon: '🛠️', name: 'kz', tagline: '新卒半年でフリーランスへ。アプリ2本リリースしてユーザーはほぼ来なかった。' },
];

const postCountByAuthor = Object.fromEntries(
	writers.map((w) => [w.id, allPosts.filter((p) => p.data.author === w.id).length])
);

const moments = [
	{
		situation: '仕事がしんどくて、誰にも言えない',
		quote: '怖いって言っても、辞めたいとかじゃなくて。ただ、自信がごっそり抜けてる感じ。',
		author: 'Yuki',
		icon: '☕',
		href: `${base}/blog/when-work-got-scary`,
	},
	{
		situation: 'がんばってるのに、誰にも言えずにいる',
		quote: 'スランプのとき、全然普通じゃなかったのに、全員に「普通だよ」って答えてた。',
		author: 'Yuki',
		icon: '☕',
		href: `${base}/blog/work-cant-show-weakness`,
	},
	{
		situation: '転職しようか、ずっと迷っている',
		quote: '辞めていいのか、って8ヶ月考え続けた。答えが出たのは、問いを変えたときだった。',
		author: 'Syun',
		icon: '💼',
		href: `${base}/blog/mindset-career-change`,
	},
];

const featuredYuki = [
	{
		situation: '帰りの電車で泣いた夜があった',
		slug: 'cried-on-the-train',
		title: '帰りの電車で泣いたことがある。仕事でミスして立ち直れなかった夜の話',
	},
	{
		situation: '女性リーダーになって、向いてないかもと思った',
		slug: 'female-leader-anxiety',
		title: '女性リーダーになって、向いてないかもと思った話',
	},
	{
		situation: '気を遣いすぎて消耗しきっていた',
		slug: 'too-considerate-exhaustion',
		title: '仕事で気を遣いすぎて消耗する。それが「優しさ」だと思っていた話',
	},
	{
		situation: '自分を責めるのをやめられなかった',
		slug: 'self-blame-cant-stop',
		title: '仕事の自己嫌悪が止まらない。自分を責めるのをやめられなかった話',
	},
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(760px, calc(100% - 2em));
				margin: 0 auto;
				padding: 0 1em 4em;
			}
			/* Hero */
			.hero {
				padding: 3.5em 1.5em 2.5em;
				margin: 0 -1.5em 2.5em;
				background: linear-gradient(160deg, rgba(232,113,74,0.06) 0%, rgba(250,249,248,0) 60%);
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.hero h1 {
				font-size: 2.2rem;
				line-height: 1.25;
				margin: 0 0 0.6em;
				letter-spacing: -0.01em;
			}
			.hero p {
				color: rgb(var(--gray));
				margin: 0 0 1.4em;
				line-height: 1.8;
				max-width: 520px;
			}
			.hero-cta {
				display: inline-flex;
				align-items: center;
				background: var(--accent);
				color: white;
				text-decoration: none;
				padding: 0.7em 1.6em;
				min-height: 44px;
				border-radius: 999px;
				font-size: 0.9rem;
				font-weight: 700;
				transition: opacity 0.15s ease;
			}
			.hero-cta:hover { opacity: 0.85; }
			/* Section */
			.section-title {
				font-size: 0.75rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.12em;
				text-transform: uppercase;
				margin: 0 0 1rem;
				display: flex;
				align-items: center;
				gap: 0.6em;
			}
			.section-title::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}
			/* Moments */
			.moments { margin-bottom: 2.5em; }
			.moment-list {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.75em;
			}
			.moment-card {
				display: block;
				padding: 1.1em 1.2em 1.1em 1.4em;
				border-left: 3px solid var(--accent);
				background: rgba(var(--gray-light), 0.35);
				border-radius: 0 10px 10px 0;
				text-decoration: none;
				color: inherit;
				transition: background 0.15s ease, border-color 0.15s ease;
			}
			.moment-card:hover {
				background: rgba(var(--gray-light), 0.6);
			}
			.moment-situation {
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.4em;
				letter-spacing: 0.02em;
			}
			.moment-quote {
				font-size: 0.95rem;
				line-height: 1.65;
				margin: 0 0 0.5em;
				color: rgb(var(--gray-dark));
			}
			.moment-attribution {
				font-size: 0.78rem;
				color: rgb(var(--gray));
			}
			/* Featured Yuki */
			.featured-yuki { margin-bottom: 2.5em; }
			.featured-yuki-list {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.75em;
			}
			.featured-yuki-card {
				display: block;
				padding: 1em 1.1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease;
			}
			.featured-yuki-card:hover { border-color: var(--accent); }
			.featured-yuki-situation {
				font-size: 0.72rem;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.4em;
				letter-spacing: 0.02em;
			}
			.featured-yuki-title {
				font-size: 0.88rem;
				font-weight: 700;
				line-height: 1.45;
				margin: 0;
				color: rgb(var(--black));
			}
			/* Categories */
			.categories { margin-bottom: 2.5em; }
			.category-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.category-list a {
				display: inline-block;
				padding: 0.4em 1.1em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				font-size: 0.85rem;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-weight: 600;
				transition: all 0.15s ease;
			}
			.category-list a:hover {
				background: var(--accent);
				color: white;
			}
			/* Writers */
			.writers { margin-bottom: 2.5em; }
			.writer-list {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.75em;
			}
			.writer-card {
				display: flex;
				flex-direction: column;
				gap: 0.3em;
				padding: 1em 1.1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease;
			}
			.writer-card:hover { border-color: var(--accent); }
			.writer-card-header {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-weight: 700;
				font-size: 0.95rem;
			}
			.writer-card-tagline {
				font-size: 0.78rem;
				color: rgb(var(--gray));
				line-height: 1.4;
			}
			.writer-card-count {
				font-size: 0.75rem;
				color: var(--accent);
				font-weight: 700;
				margin-top: 0.2em;
			}
			/* Recent posts */
			.recent { margin-bottom: 2em; }
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
			}
			.post-list li { padding: 1.4em 0; border-bottom: 1px solid rgb(var(--gray-light)); }
			.post-list li:first-child { padding-top: 0; }
			.post-list a {
				display: block;
				text-decoration: none;
				color: inherit;
				padding: 0.6em 0.8em;
				margin: -0.6em -0.8em;
				border-radius: 8px;
				transition: background 0.15s ease;
			}
			.post-list a:hover { background: rgba(var(--gray-light), 0.5); }
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.78rem;
				margin-bottom: 0.5em;
			}
			.author-chip { font-weight: 700; color: rgb(var(--gray-dark)); }
			.category-chip {
				background: var(--accent);
				color: white;
				font-size: 0.68rem;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-weight: 700;
			}
			.date-chip { color: rgb(var(--gray)); margin-left: auto; }
			.post-title {
				font-size: 1.05rem;
				font-weight: 700;
				margin: 0 0 0.3em;
				line-height: 1.45;
				color: rgb(var(--black));
			}
			.post-desc {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.6;
			}
			.all-link {
				display: inline-block;
				margin-top: 1.2em;
				font-size: 0.875rem;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.all-link:hover { text-decoration: underline; }
			/* Desktop enhancements */
			@media (min-width: 600px) {
				.moment-list {
					grid-template-columns: 1fr 1fr;
				}
				.moment-list .moment-card:first-child {
					grid-column: 1 / -1;
				}
			}
			@media (max-width: 599px) {
				.hero {
					padding: 2.5em 1em 2em;
					margin: 0 -1em 2em;
				}
				.hero h1 { font-size: 1.6rem; }
				.date-chip { display: none; }
				.featured-yuki-list { grid-template-columns: 1fr; }
				.writer-list { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1>迷いながら進む、それでいい。</h1>
				<p>転職・働き方・しんどさ——キャリアに迷う人たちのリアルな体験談を、現役の営業職・コンサルタント・エンジニアが書いています。</p>
				<a class="hero-cta" href={`${base}/blog/author/yuki`}>☕ Yukiの記事を読む</a>
			</section>

			<!-- Moments -->
			<section class="moments">
				<p class="section-title">こんな時に読んでほしい</p>
				<div class="moment-list">
					{moments.map((m) => (
						<a class="moment-card" href={m.href}>
							<div class="moment-situation">{m.situation}</div>
							<p class="moment-quote">「{m.quote}」</p>
							<div class="moment-attribution">{m.icon} {m.author}</div>
						</a>
					))}
				</div>
			</section>

			<!-- Featured Yuki -->
			<section class="featured-yuki">
				<p class="section-title">☕ Yukiの記事</p>
				<div class="featured-yuki-list">
					{featuredYuki.map((a) => (
						<a class="featured-yuki-card" href={`${base}/blog/${a.slug}/`}>
							<div class="featured-yuki-situation">{a.situation}</div>
							<p class="featured-yuki-title">{a.title}</p>
						</a>
					))}
				</div>
				<a class="all-link" href={`${base}/blog/author/yuki`}>Yukiの記事をすべて見る →</a>
			</section>

			<!-- Recent posts -->
			<section class="recent">
				<p class="section-title">最新記事</p>
				<ul class="post-list">
					{recentPosts.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="post-meta">
									{post.data.author && (
										<span class="author-chip">
											{post.data.author === 'yuki' ? '☕ Yuki' : post.data.author === 'kz' ? '🛠️ kz' : '💼 Syun'}
										</span>
									)}
									{post.data.category && (
										<span class="category-chip">{post.data.category}</span>
									)}
									<span class="date-chip">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
				<a class="all-link" href={`${base}/blog`}>すべての記事を見る →</a>
			</section>

			<!-- Categories -->
			<section class="categories">
				<p class="section-title">カテゴリ</p>
				<div class="category-list">
					{categories.map((cat) => (
						<a href={`${base}/blog/category/${cat}`}>{cat}</a>
					))}
				</div>
			</section>

			<!-- Writers -->
			<section class="writers">
				<p class="section-title">ライターで探す</p>
				<div class="writer-list">
					{writers.map((w) => (
						<a class="writer-card" href={`${base}/blog/author/${w.id}`}>
							<div class="writer-card-header">
								<span>{w.icon}</span>
								<span>{w.name}</span>
							</div>
							<div class="writer-card-tagline">{w.tagline}</div>
							<div class="writer-card-count">{postCountByAuthor[w.id]}件の記事</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
