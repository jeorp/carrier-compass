---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const writers = [
	{
		id: 'syun',
		icon: '💼',
		name: 'Syun',
		desc: '外資系コンサル出身のキャリアコンサルタント。年収900万を手放した経験から、転職の決断や高収入層の悩みを書く。',
	},
	{
		id: 'yuki',
		icon: '☕',
		name: 'Yuki',
		desc: '大手メーカーからスタートアップへ転職した29歳の営業職。1年目のしんどさや、働くことの等身大の話を書く。',
	},
	{
		id: 'kz',
		icon: '🛠️',
		name: 'kz',
		desc: '26歳のソフトウェアエンジニア。新卒半年でフリーランスになった経験から、エンジニアのキャリアや学び方を書く。',
	},
];

const categories = ['転職', 'スキルアップ', '副業', '働き方'];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2em 1em 4em;
			}
			.hero {
				padding: 2.5em 0 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
			}
			.hero h1 {
				font-size: 1.8rem;
				line-height: 1.3;
				margin: 0 0 0.6em;
			}
			.hero p {
				color: rgb(var(--gray));
				margin: 0 0 1.2em;
				line-height: 1.7;
			}
			.hero-cta {
				display: inline-block;
				background: var(--accent);
				color: white;
				text-decoration: none;
				padding: 0.5em 1.2em;
				border-radius: 999px;
				font-size: 0.9rem;
				font-weight: 700;
				transition: opacity 0.15s ease;
			}
			.hero-cta:hover {
				opacity: 0.85;
			}
			.section-title {
				font-size: 0.8rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin: 0 0 1rem;
			}
			/* Writers */
			.writers {
				margin-bottom: 2.5em;
			}
			.writer-list {
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.writer-card {
				display: flex;
				align-items: flex-start;
				gap: 1em;
				padding: 1.2em;
				background: rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: background 0.15s ease;
			}
			.writer-card:hover {
				background: rgb(var(--gray-light), 0.7);
				opacity: 0.85;
			}
			.writer-icon {
				font-size: 2rem;
				line-height: 1;
				flex-shrink: 0;
			}
			.writer-name {
				font-weight: 700;
				margin-bottom: 0.2em;
			}
			.writer-desc {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.6;
			}
			/* Categories */
			.categories {
				margin-bottom: 2.5em;
			}
			.category-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.category-list a {
				display: inline-block;
				padding: 0.4em 1em;
				border-radius: 999px;
				border: 1px solid rgb(var(--gray-light));
				font-size: 0.85rem;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: all 0.15s ease;
			}
			.category-list a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			/* Recent posts */
			.recent {
				margin-bottom: 2em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
			}
			.post-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 1.5em 0;
			}
			.post-list li:first-child {
				padding-top: 0;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.8rem;
				margin-bottom: 0.5em;
			}
			.author-chip {
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.category-chip {
				background: var(--accent);
				color: white;
				font-size: 0.7rem;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-weight: 700;
			}
			.date-chip {
				color: rgb(var(--gray));
				margin-left: auto;
			}
			.post-title {
				font-size: 1.1rem;
				font-weight: 700;
				margin: 0 0 0.3em;
				line-height: 1.4;
				display: inline;
				background-image: linear-gradient(var(--accent), var(--accent));
				background-size: 0% 2px;
				background-repeat: no-repeat;
				background-position: left bottom;
				transition: background-size 0.25s ease;
			}
			.post-list a:hover .post-title {
				background-size: 100% 2px;
			}
			.post-desc {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.6;
			}
			.all-link {
				display: inline-block;
				margin-top: 1.2em;
				font-size: 0.875rem;
				color: var(--accent);
				text-decoration: none;
			}
			.all-link:hover {
				text-decoration: underline;
			}
			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.4rem;
				}
				.date-chip {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1>迷いながら進む、それでいい。</h1>
				<p>転職・働き方・スキルアップ・副業——キャリアに悩む人たちのリアルな体験談を、現役のコンサルタント・営業職・エンジニアが書いています。</p>
				<a class="hero-cta" href={`${base}/blog`}>記事を読む</a>
			</section>

			<!-- Writers -->
			<section class="writers">
				<p class="section-title">ライター</p>
				<div class="writer-list">
					{writers.map((w) => (
						<a class="writer-card" href={`${base}/blog/author/${w.id}`}>
							<div class="writer-icon">{w.icon}</div>
							<div>
								<div class="writer-name">{w.name}</div>
								<p class="writer-desc">{w.desc}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Categories -->
			<section class="categories">
				<p class="section-title">カテゴリ</p>
				<div class="category-list">
					{categories.map((cat) => (
						<a href={`${base}/blog/category/${cat}`}>{cat}</a>
					))}
				</div>
			</section>

			<!-- Recent posts -->
			<section class="recent">
				<p class="section-title">最新記事</p>
				<ul class="post-list">
					{recentPosts.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="post-meta">
									{post.data.author && (
										<span class="author-chip">
											{post.data.author === 'yuki' ? '☕ Yuki' : post.data.author === 'kz' ? '🛠️ kz' : '💼 Syun'}
										</span>
									)}
									{post.data.category && (
										<span class="category-chip">{post.data.category}</span>
									)}
									<span class="date-chip">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
				<a class="all-link" href={`${base}/blog`}>すべての記事を見る →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
