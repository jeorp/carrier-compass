---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = ['転職', 'スキルアップ', '副業', '働き方'];



const moments = [
	{
		situation: '仕事がしんどくて、誰にも言えない',
		quote: '怖いって言っても、辞めたいとかじゃなくて。ただ、自信がごっそり抜けてる感じ。',
		author: 'Yuki',
		icon: '☕',
		href: `${base}/blog/when-work-got-scary`,
	},
	{
		situation: 'がんばってるのに、誰にも言えずにいる',
		quote: 'スランプのとき、全然普通じゃなかったのに、全員に「普通だよ」って答えてた。',
		author: 'Yuki',
		icon: '☕',
		href: `${base}/blog/work-cant-show-weakness`,
	},
	{
		situation: '転職しようか、ずっと迷っている',
		quote: '辞めていいのか、って8ヶ月考え続けた。答えが出たのは、問いを変えたときだった。',
		author: 'Syun',
		icon: '💼',
		href: `${base}/blog/mindset-career-change`,
	},
];

const featuredYuki = [
	{
		situation: '帰りの電車で泣いた夜があった',
		slug: 'cried-on-the-train',
		title: '帰りの電車で泣いたことがある。仕事でミスして立ち直れなかった夜の話',
	},
	{
		situation: '女性リーダーになって、向いてないかもと思った',
		slug: 'female-leader-anxiety',
		title: '女性リーダーになって、向いてないかもと思った話',
	},
	{
		situation: '気を遣いすぎて消耗しきっていた',
		slug: 'too-considerate-exhaustion',
		title: '仕事で気を遣いすぎて消耗する。それが「優しさ」だと思っていた話',
	},
	{
		situation: '自分を責めるのをやめられなかった',
		slug: 'self-blame-cant-stop',
		title: '仕事の自己嫌悪が止まらない。自分を責めるのをやめられなかった話',
	},
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(760px, calc(100% - 2em));
				margin: 0 auto;
				padding: 0 1em 4em;
			}
			/* Hero */
			.hero {
				padding: 3.5em 1.5em 2.5em;
				margin: 0 -1.5em 2.5em;
				background: linear-gradient(160deg, rgba(232,113,74,0.06) 0%, rgba(250,249,248,0) 60%);
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.hero h1 {
				font-size: 2.2rem;
				line-height: 1.25;
				margin: 0 0 0.6em;
				letter-spacing: -0.01em;
			}
			.hero p {
				color: rgb(var(--gray));
				margin: 0 0 1.4em;
				line-height: 1.8;
				max-width: 520px;
			}
			.hero-cta {
				display: inline-flex;
				align-items: center;
				background: var(--accent);
				color: white;
				text-decoration: none;
				padding: 0.7em 1.6em;
				min-height: 44px;
				border-radius: 999px;
				font-size: 0.9rem;
				font-weight: 700;
				transition: opacity 0.15s ease;
			}
			.hero-cta:hover { opacity: 0.85; }
			/* Section */
			.section-title {
				font-size: 0.75rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.12em;
				text-transform: uppercase;
				margin: 0 0 1rem;
				display: flex;
				align-items: center;
				gap: 0.6em;
			}
			.section-title::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}
			/* Moments */
			.moments { margin-bottom: 2.5em; }
			.moment-list {
				display: grid;
				grid-template-columns: 1fr;
				gap: 0.75em;
			}
			.moment-card {
				display: block;
				padding: 1.1em 1.2em 1.1em 1.4em;
				border-left: 3px solid var(--accent);
				background: rgba(var(--gray-light), 0.35);
				border-radius: 0 10px 10px 0;
				text-decoration: none;
				color: inherit;
				transition: background 0.15s ease, border-color 0.15s ease;
			}
			.moment-card:hover {
				background: rgba(var(--gray-light), 0.6);
			}
			.moment-situation {
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.4em;
				letter-spacing: 0.02em;
			}
			.moment-quote {
				font-size: 0.95rem;
				line-height: 1.65;
				margin: 0 0 0.5em;
				color: rgb(var(--gray-dark));
			}
			.moment-attribution {
				font-size: 0.78rem;
				color: rgb(var(--gray));
			}
			/* Featured Yuki */
			.featured-yuki { margin-bottom: 2.5em; }
			.featured-yuki-list {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.75em;
			}
			.featured-yuki-card {
				display: block;
				padding: 1em 1.1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease;
			}
			.featured-yuki-card:hover { border-color: var(--accent); }
			.featured-yuki-situation {
				font-size: 0.72rem;
				font-weight: 700;
				color: var(--accent);
				margin-bottom: 0.4em;
				letter-spacing: 0.02em;
			}
			.featured-yuki-title {
				font-size: 0.88rem;
				font-weight: 700;
				line-height: 1.45;
				margin: 0;
				color: rgb(var(--black));
			}
			/* Categories */
			.categories { margin-bottom: 2.5em; }
			.category-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.category-list a {
				display: inline-block;
				padding: 0.4em 1.1em;
				border-radius: 999px;
				background: rgb(var(--gray-light));
				font-size: 0.85rem;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				font-weight: 600;
				transition: all 0.15s ease;
			}
			.category-list a:hover {
				background: var(--accent);
				color: white;
			}
			.all-link {
				display: inline-block;
				margin-top: 1.2em;
				font-size: 0.875rem;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.all-link:hover { text-decoration: underline; }
			/* Yuki's pick */
			.yuki-pick {
				margin-bottom: 2.5em;
			}
			.yuki-pick-card {
				display: flex;
				align-items: center;
				gap: 1em;
				padding: 1.1em 1.3em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.15s ease;
			}
			.yuki-pick-card:hover { border-color: var(--accent); }
			.yuki-pick-icon {
				font-size: 2rem;
				flex-shrink: 0;
			}
			.yuki-pick-body {
				flex: 1;
				min-width: 0;
			}
			.yuki-pick-label {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.72rem;
				font-weight: 700;
				color: var(--accent);
				letter-spacing: 0.05em;
				margin-bottom: 0.3em;
			}
			.yuki-pick-pr {
				font-size: 0.65rem;
				font-weight: 700;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				padding: 0.1em 0.45em;
				border-radius: 3px;
				letter-spacing: 0.03em;
			}
			.yuki-pick-name {
				font-size: 0.95rem;
				font-weight: 700;
				margin: 0 0 0.25em;
				color: rgb(var(--black));
			}
			.yuki-pick-desc {
				font-size: 0.82rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.55;
			}
			.yuki-pick-arrow {
				font-size: 0.9rem;
				color: rgb(var(--gray));
				flex-shrink: 0;
			}
			/* Desktop enhancements */
			@media (min-width: 600px) {
				.moment-list {
					grid-template-columns: 1fr 1fr;
				}
				.moment-list .moment-card:first-child {
					grid-column: 1 / -1;
				}
			}
			@media (max-width: 599px) {
				.hero {
					padding: 2.5em 1em 2em;
					margin: 0 -1em 2em;
				}
				.hero h1 { font-size: 1.6rem; }
				.date-chip { display: none; }
				.featured-yuki-list { grid-template-columns: 1fr; }
				.writer-list { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1>迷いながら進む、それでいい。</h1>
				<p>転職・働き方・しんどさ——キャリアに迷う人たちのリアルな体験談を、現役の営業職・コンサルタント・エンジニアが書いています。</p>
				<a class="hero-cta" href={`${base}/blog/author/yuki`}>☕ Yukiの記事を読む</a>
			</section>

			<!-- Moments -->
			<section class="moments">
				<p class="section-title">こんな時に読んでほしい</p>
				<div class="moment-list">
					{moments.map((m) => (
						<a class="moment-card" href={m.href}>
							<div class="moment-situation">{m.situation}</div>
							<p class="moment-quote">「{m.quote}」</p>
							<div class="moment-attribution">{m.icon} {m.author}</div>
						</a>
					))}
				</div>
			</section>

			<!-- Featured Yuki -->
			<section class="featured-yuki">
				<p class="section-title">☕ Yukiの記事</p>
				<div class="featured-yuki-list">
					{featuredYuki.map((a) => (
						<a class="featured-yuki-card" href={`${base}/blog/${a.slug}/`}>
							<div class="featured-yuki-situation">{a.situation}</div>
							<p class="featured-yuki-title">{a.title}</p>
						</a>
					))}
				</div>
				<a class="all-link" href={`${base}/blog/author/yuki`}>Yukiの記事をすべて見る →</a>
			</section>


			<!-- Categories -->
			<section class="categories">
				<p class="section-title">カテゴリ</p>
				<div class="category-list">
					{categories.map((cat) => (
						<a href={`${base}/blog/category/${cat}`}>{cat}</a>
					))}
				</div>
			</section>

			<!-- Yuki's pick -->
			<section class="yuki-pick">
				<p class="section-title">☕ Yukiのお気に入り</p>
				<a class="yuki-pick-card" href="https://px.a8.net/svt/ejp?a8mat=4AZJGB+CI4HE+5UFU+5YJRM" rel="nofollow" target="_blank">
					<div class="yuki-pick-icon">☕</div>
					<div class="yuki-pick-body">
						<div class="yuki-pick-label">Yukiが愛用中のコーヒー<span class="yuki-pick-pr">PR</span></div>
						<p class="yuki-pick-name">ブルーボトルコーヒー 公式オンラインストア</p>
						<p class="yuki-pick-desc">しんどい日の帰り道、自宅でドリップする10分が切り替えの合図。豆はここで取り寄せてる。</p>
					</div>
					<div class="yuki-pick-arrow">→</div>
				</a>
				<img src="https://www14.a8.net/0.gif?a8mat=4AZJGB+CI4HE+5UFU+5YJRM" width="1" height="1" alt="" style="display:none;" />
			</section>
		</main>
		<Footer />
	</body>
</html>
