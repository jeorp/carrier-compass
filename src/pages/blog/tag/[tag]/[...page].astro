---
import { getCollection } from 'astro:content';
import BaseHead from '../../../../components/BaseHead.astro';
import Footer from '../../../../components/Footer.astro';
import FormattedDate from '../../../../components/FormattedDate.astro';
import Header from '../../../../components/Header.astro';
import { SITE_TITLE } from '../../../../consts';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
	const posts = await getCollection('blog');
	const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
	return tags.flatMap((tag) => {
		const filtered = posts
			.filter((p) => p.data.tags?.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return paginate(filtered, { params: { tag }, pageSize: 8 });
	});
}

const { tag } = Astro.params;
const { page } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const readingTime = (body: string) => Math.max(1, Math.ceil(body.length / 500));
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={page.currentPage === 1 ? `#${tag} | ${SITE_TITLE}` : `#${tag} — ${page.currentPage}ページ目 | ${SITE_TITLE}`}
			description={`#${tag}の記事一覧`}
		/>
		<style>
			main { width: 680px; }
			.feed-header {
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			h2.feed-title {
				font-size: 1rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				margin: 0 0 0.5rem 0;
			}
			.tag-label {
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 0.25rem;
			}
			.back-link {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				text-decoration: none;
				display: inline-block;
				margin-top: 0.5rem;
			}
			.back-link:hover { color: var(--accent); }
			ul { list-style-type: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
			ul li { border-bottom: 1px solid rgb(var(--gray-light)); padding: 1.75rem 0; }
			ul li:first-child { padding-top: 0; }
			ul li a { display: block; text-decoration: none; color: inherit; }
			.card-meta { display: flex; align-items: center; gap: 0.6em; margin-bottom: 0.6rem; font-size: 0.8rem; }
			.author-chip { font-weight: 700; color: rgb(var(--gray-dark)); }
			.category-chip {
				background: var(--accent);
				color: white;
				font-size: 0.7rem;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-weight: 700;
			}
			.date-chip { color: rgb(var(--gray)); margin-left: auto; }
			.reading-time { color: rgb(var(--gray)); }
			.title {
				margin: 0 0 0.4rem 0;
				font-size: 1.2rem;
				line-height: 1.4;
				color: rgb(var(--black));
				display: inline;
				background-image: linear-gradient(var(--accent), var(--accent));
				background-size: 0% 2px;
				background-repeat: no-repeat;
				background-position: left bottom;
				transition: background-size 0.25s ease;
			}
			ul li a:hover .title { background-size: 100% 2px; }
			.description { margin: 0; font-size: 0.9rem; color: rgb(var(--gray)); line-height: 1.6; }
			.pagination {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 2rem 0 1rem;
				gap: 1em;
			}
			.pagination a, .pagination span {
				display: flex;
				align-items: center;
				justify-content: center;
				min-width: 44px;
				min-height: 44px;
				padding: 0 1em;
				border-radius: 999px;
				font-size: 0.875rem;
				font-weight: 600;
				text-decoration: none;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				transition: all 0.15s ease;
			}
			.pagination a:hover { border-color: var(--accent); color: var(--accent); }
			.pagination .disabled { opacity: 0.3; pointer-events: none; }
			.pagination .page-info { border: none; font-size: 0.85rem; color: rgb(var(--gray)); min-width: auto; }
			@media (max-width: 720px) {
				main { width: 100%; }
				.date-chip { display: none; }
				.title { font-size: 1rem; }
				.description { font-size: 0.85rem; }
				ul li { padding: 1.25rem 0; }
				.pagination { padding: 1.5rem 0 0.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="feed-header">
					<h2 class="feed-title">タグ</h2>
					<div class="tag-label">#{tag}</div>
					<a class="back-link" href={`${base}/blog`}>← すべての記事へ</a>
				</div>
				<ul>
					{page.data.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="card-meta">
									{post.data.author && (
										<span class="author-chip">
											{post.data.author === 'yuki' ? '☕ Yuki' : post.data.author === 'kz' ? '🛠️ kz' : '💼 Syun'}
										</span>
									)}
									<span class="category-chip">{post.data.category}</span>
									<span class="date-chip">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<span class="reading-time">約{readingTime(post.body)}分</span>
								</div>
								<h4 class="title">{post.data.title}</h4>
								{post.data.description && (
									<p class="description">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
				{page.lastPage > 1 && (
					<nav class="pagination">
						{page.url.prev
							? <a href={page.url.prev}>← 新しい記事</a>
							: <span class="disabled">← 新しい記事</span>
						}
						<span class="page-info">{page.currentPage} / {page.lastPage}</span>
						{page.url.next
							? <a href={page.url.next}>古い記事 →</a>
							: <span class="disabled">古い記事 →</span>
						}
					</nav>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
