---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
	return tags.map((tag) => ({
		params: { tag },
		props: {
			posts: posts
				.filter((p) => p.data.tags?.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`#${tag} | ${SITE_TITLE}`} description={`#${tag}の記事一覧`} />
		<style>
			main { width: 680px; }
			.feed-header {
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			h2.feed-title {
				font-size: 1rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				margin: 0 0 0.5rem 0;
			}
			.tag-label {
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 0.25rem;
			}
			.back-link {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				text-decoration: none;
				display: inline-block;
				margin-top: 0.5rem;
			}
			.back-link:hover { color: var(--accent); }
			ul { list-style-type: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
			ul li { border-bottom: 1px solid rgb(var(--gray-light)); padding: 1.75rem 0; }
			ul li:first-child { padding-top: 0; }
			ul li a { display: block; text-decoration: none; color: inherit; }
			.card-meta { display: flex; align-items: center; gap: 0.6em; margin-bottom: 0.6rem; font-size: 0.8rem; }
			.author-chip { font-weight: 700; color: rgb(var(--gray-dark)); }
			.category-chip {
				background: var(--accent);
				color: white;
				font-size: 0.7rem;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-weight: 700;
			}
			.date-chip { color: rgb(var(--gray)); margin-left: auto; }
			.title {
				margin: 0 0 0.4rem 0;
				font-size: 1.2rem;
				line-height: 1.4;
				color: rgb(var(--black));
				display: inline;
				background-image: linear-gradient(var(--accent), var(--accent));
				background-size: 0% 2px;
				background-repeat: no-repeat;
				background-position: left bottom;
				transition: background-size 0.25s ease;
			}
			ul li a:hover .title { background-size: 100% 2px; }
			.description { margin: 0; font-size: 0.9rem; color: rgb(var(--gray)); line-height: 1.6; }
			@media (max-width: 720px) {
				main { width: 100%; }
				.date-chip { display: none; }
				.title { font-size: 1rem; }
				ul li { padding: 1.25rem 0; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="feed-header">
					<h2 class="feed-title">タグ</h2>
					<div class="tag-label">#{tag}</div>
					<a class="back-link" href={`${base}/blog`}>← すべての記事へ</a>
				</div>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="card-meta">
									{post.data.author && (
										<span class="author-chip">
											{post.data.author === 'yuki' ? '☕ Yuki' : post.data.author === 'kz' ? '🛠️ kz' : '💼 Syun'}
										</span>
									)}
									<span class="category-chip">{post.data.category}</span>
									<span class="date-chip">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								<h4 class="title">{post.data.title}</h4>
								{post.data.description && (
									<p class="description">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
