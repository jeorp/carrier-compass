---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

const categories = ['転職', 'スキルアップ', '副業', '働き方'] as const;

export async function getStaticPaths() {
	const categories = ['転職', 'スキルアップ', '副業', '働き方'] as const;
	const posts = await getCollection('blog');
	return categories.map((category) => ({
		params: { category },
		props: {
			posts: posts
				.filter((p) => p.data.category === category)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { category } = Astro.params;
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${category} | ${SITE_TITLE}`} description={`${category}に関する記事一覧`} />
		<style>
			main {
				width: 680px;
			}
			.feed-header {
				margin-bottom: 2rem;
				padding-bottom: 0.5rem;
				border-bottom: 2px solid rgb(var(--gray-light));
			}
			h2.feed-title {
				font-size: 1rem;
				font-weight: 700;
				color: rgb(var(--gray));
				letter-spacing: 0.1em;
				margin: 0 0 1rem 0;
			}
			.category-filters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.category-filters a {
				font-size: 0.8rem;
				padding: 0.3em 0.8em;
				border-radius: 999px;
				text-decoration: none;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray));
				transition: all 0.15s ease;
			}
			.category-filters a:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.category-filters a.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
				font-weight: 700;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
			}
			ul li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 1.75rem 0;
			}
			ul li:first-child {
				padding-top: 0;
			}
			ul li a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.card-meta {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.6rem;
				font-size: 0.8rem;
			}
			.author-chip {
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.category-chip {
				background: var(--accent);
				color: white;
				font-size: 0.7rem;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-weight: 700;
			}
			.date-chip {
				color: rgb(var(--gray));
				margin-left: auto;
			}
			.title {
				margin: 0 0 0.4rem 0;
				font-size: 1.2rem;
				line-height: 1.4;
				color: rgb(var(--black));
				display: inline;
				background-image: linear-gradient(var(--accent), var(--accent));
				background-size: 0% 2px;
				background-repeat: no-repeat;
				background-position: left bottom;
				transition: background-size 0.25s ease;
			}
			ul li a:hover .title {
				background-size: 100% 2px;
			}
			.description {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				line-height: 1.6;
			}
			.empty {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				padding: 2rem 0;
			}
			@media (max-width: 720px) {
				main { width: 100%; }
				.date-chip { display: none; }
				.title { font-size: 1rem; }
				.description { font-size: 0.85rem; }
				ul li { padding: 1.25rem 0; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="feed-header">
					<h2 class="feed-title">カテゴリ</h2>
					<div class="category-filters">
						<a href={`${base}/blog`}>すべて</a>
						{categories.map((cat) => (
							<a
								href={`${base}/blog/category/${cat}`}
								class={cat === category ? 'active' : ''}
							>{cat}</a>
						))}
					</div>
				</div>
				{posts.length === 0 ? (
					<p class="empty">このカテゴリの記事はまだありません。</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`${base}/blog/${post.id}/`}>
									<div class="card-meta">
										{post.data.author && (
											<span class="author-chip">
												{post.data.author === 'yuki' ? '☕ Yuki' : post.data.author === 'kenta' ? '🛠️ Kenta' : '💼 Syun'}
											</span>
										)}
										<span class="category-chip">{post.data.category}</span>
										<span class="date-chip">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<h4 class="title">{post.data.title}</h4>
									{post.data.description && (
										<p class="description">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
