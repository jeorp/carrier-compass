---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`}>ホーム</HeaderLink>
			<HeaderLink href={`${base}/blog`}>ブログ</HeaderLink>
			<HeaderLink href={`${base}/about`}>このサイトについて</HeaderLink>
		</div>
	</nav>
</header>

<nav class="bottom-nav" aria-label="メインナビゲーション">
	<HeaderLink href={`${base}/`}>
		<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
		<span>ホーム</span>
	</HeaderLink>
	<HeaderLink href={`${base}/blog`}>
		<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
		<span>ブログ</span>
	</HeaderLink>
	<HeaderLink href={`${base}/about`}>
		<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
		<span>について</span>
	</HeaderLink>
</nav>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	/* Bottom nav: モバイルのみ表示 */
	.bottom-nav {
		display: none;
	}
	@media (max-width: 720px) {
		.internal-links {
			display: none;
		}
		.bottom-nav {
			display: flex;
			position: fixed;
			bottom: 0;
			left: 0;
			right: 0;
			height: 60px;
			background: white;
			border-top: 1px solid rgb(var(--gray-light));
			box-shadow: 0 -2px 8px rgba(var(--black), 5%);
			z-index: 100;
			padding-bottom: env(safe-area-inset-bottom);
		}
		.bottom-nav a {
			flex: 1;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 3px;
			padding: 0;
			border-bottom: none;
			color: rgb(var(--gray));
			font-size: 0.7rem;
			text-decoration: none;
		}
		.bottom-nav a.active {
			color: var(--accent);
			border-bottom: none;
		}
		.bottom-nav a svg {
			display: block;
		}
	}
</style>
